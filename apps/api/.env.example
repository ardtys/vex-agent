# ========================================
# VEX API - Environment Variables
# ========================================
# For local: Copy this file to .env and fill in values
# For Vercel: Set these in Vercel Dashboard > Settings > Environment Variables

# Solana RPC (Required)
# Get your API key from https://helius.dev
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# AI Model (Required)
# Get your API key from https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-xxxx
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct

# CORS (Required for Production)
# Set to your frontend Vercel URL
CORS_ORIGIN=https://vex-web.vercel.app

# Environment
NODE_ENV=production
