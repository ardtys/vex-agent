# VEX API - Production Environment Variables
# Copy these to Vercel Dashboard > vex-api > Settings > Environment Variables

# ============ REQUIRED ============

# Solana RPC (Helius)
HELIUS_API_KEY=your_helius_api_key
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key

# AI/LLM (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct

# Market Data (Birdeye)
BIRDEYE_API_KEY=your_birdeye_api_key

# Security
CORS_ORIGIN=https://your-vex-web.vercel.app
JWT_SECRET=generate_a_secure_random_string_min_32_chars

# Environment
NODE_ENV=production

# ============ OPTIONAL ============

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Twitter API (for social features)
TWITTER_BEARER_TOKEN=

# Pump.fun Integration
PUMPFUN_PRIVATE_KEY=
