# ========================================
# VEX Web - Environment Variables
# ========================================
# For local: Copy this file to .env and fill in values
# For Vercel: Set these in Vercel Dashboard > Settings > Environment Variables

# API URL (Required)
# Local development: http://localhost:4000
# Production: Your deployed API URL (e.g., https://vex-api.vercel.app)
VITE_API_URL=https://vex-api.vercel.app
